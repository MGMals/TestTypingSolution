  "components": {
    "schemas": {
      "LoginModel": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterModel": {
        "required": [
          "country",
          "email",
          "firstName",
          "lastName",
          "password"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "country": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 10,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TestTypeUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "passwordHash": {
            "type": "string",
            "nullable": true
          },
          "typingTests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TypingTest"
            },
            "nullable": true
          },
          "userSessions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserSession"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TypingTest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "wpm": {
            "type": "integer",
            "format": "int32"
          },
          "accuracy": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "charactersTyped": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "errors": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "testDuration": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "difficulty": {
            "type": "string",
            "nullable": true
          },
          "testDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/TestTypeUser"
          }
        },
        "additionalProperties": false
      },
      "UserSession": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "token": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/TestTypeUser"
          }
        },
        "additionalProperties": false
